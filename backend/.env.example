# ============================================================
# RiseUp Backend Environment Variables
# Copy to .env and fill in your values
# ============================================================

# App
APP_NAME=RiseUp
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production
FRONTEND_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================
# AI Model API Keys (use whichever you have — app auto-selects)
# ============================================================

# Groq (FREE - Primary AI engine)
# Get free key: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# Google Gemini (FREE tier - Secondary)
# Get free key: https://aistudio.google.com
GEMINI_API_KEY=AIzaxxxxxxxxxx

# Cohere (FREE tier - Tertiary)
# Get free key: https://dashboard.cohere.com
COHERE_API_KEY=xxxxxxxxxxxxxxxxxx

# OpenAI (Paid - used only if above fail)
# https://platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxx

# Anthropic Claude (Paid - fallback)
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# AI Model Preference (auto = smart selection)
AI_PREFERENCE=auto

# ============================================================
# Flutterwave (Payments)
# Get keys: https://dashboard.flutterwave.com
# ============================================================
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-secret

# Subscription Prices (in local currency by default)
SUBSCRIPTION_MONTHLY_USD=15.99
SUBSCRIPTION_YEARLY_USD=99.99

# ============================================================
# AdMob (handled client-side, but IDs tracked here)
# ============================================================
ADMOB_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx
ADMOB_REWARDED_AD_UNIT=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx

# ============================================================
# CORS
# ============================================================
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
